rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true;
    }

    function isSelf(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isTicketParticipantData(data) {
      return isAuthenticated() && (
        (data.customerUid is string && data.customerUid == request.auth.uid) ||
        (data.participantUids is list && request.auth.uid in data.participantUids)
      );
    }

    function isTicketParticipant(ticketId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/supportTickets/$(ticketId)) &&
        isTicketParticipantData(get(/databases/$(database)/documents/supportTickets/$(ticketId)).data);
    }

    function isPartnershipParticipant(dealId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/partnershipDeals/$(dealId)) &&
        (
          get(/databases/$(database)/documents/partnershipDeals/$(dealId)).data.participantUids is list &&
          request.auth.uid in get(/databases/$(database)/documents/partnershipDeals/$(dealId)).data.participantUids
        );
    }

    function isEmploymentOwnerWrite() {
      return isAuthenticated() && (
        (request.resource != null &&
          request.resource.data.ownerUid is string &&
          request.resource.data.ownerUid == request.auth.uid) ||
        (resource != null &&
          resource.data.ownerUid is string &&
          resource.data.ownerUid == request.auth.uid)
      );
    }

    function isPerformanceReviewerWrite() {
      return isAuthenticated() && (
        (request.resource != null &&
          request.resource.data.reviewedByUid is string &&
          request.resource.data.reviewedByUid == request.auth.uid) ||
        (resource != null &&
          resource.data.reviewedByUid is string &&
          resource.data.reviewedByUid == request.auth.uid)
      );
    }

    function isBusinessOwner(applicationId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/businessApplications/$(applicationId)) &&
        get(/databases/$(database)/documents/businessApplications/$(applicationId)).data.ownerUid is string &&
        get(/databases/$(database)/documents/businessApplications/$(applicationId)).data.ownerUid == request.auth.uid;
    }

    function isQuestionParticipant(applicationId, questionId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/businessApplications/$(applicationId)/questions/$(questionId)) &&
        (
          (get(/databases/$(database)/documents/businessApplications/$(applicationId)/questions/$(questionId)).data.customerUid is string &&
            get(/databases/$(database)/documents/businessApplications/$(applicationId)/questions/$(questionId)).data.customerUid == request.auth.uid) ||
          (get(/databases/$(database)/documents/businessApplications/$(applicationId)/questions/$(questionId)).data.ownerUid is string &&
            get(/databases/$(database)/documents/businessApplications/$(applicationId)/questions/$(questionId)).data.ownerUid == request.auth.uid) ||
          (get(/databases/$(database)/documents/businessApplications/$(applicationId)/questions/$(questionId)).data.participantUids is list &&
            request.auth.uid in get(/databases/$(database)/documents/businessApplications/$(applicationId)/questions/$(questionId)).data.participantUids)
        );
    }

    function canReadQuestionThread(applicationId, questionId) {
      return exists(/databases/$(database)/documents/businessApplications/$(applicationId)/questions/$(questionId)) &&
        (
          get(/databases/$(database)/documents/businessApplications/$(applicationId)/questions/$(questionId)).data.mode == "public" ||
          isAdmin() ||
          isBusinessOwner(applicationId) ||
          isQuestionParticipant(applicationId, questionId)
        );
    }

    function hasUserOwnership(data) {
      return (
        (data.ownerUid is string && data.ownerUid == request.auth.uid) ||
        (data.userUid is string && data.userUid == request.auth.uid) ||
        (data.customerUid is string && data.customerUid == request.auth.uid) ||
        (data.employeeUid is string && data.employeeUid == request.auth.uid) ||
        (data.followerUid is string && data.followerUid == request.auth.uid) ||
        (data.addedByUid is string && data.addedByUid == request.auth.uid) ||
        (data.createdBy is string && data.createdBy == request.auth.uid) ||
        (data.senderUid is string && data.senderUid == request.auth.uid) ||
        (data.actorUid is string && data.actorUid == request.auth.uid) ||
        (data.businessOwnerUid is string && data.businessOwnerUid == request.auth.uid) ||
        (data.initiatorUid is string && data.initiatorUid == request.auth.uid) ||
        (data.payerUid is string && data.payerUid == request.auth.uid) ||
        (data.targetUid is string && data.targetUid == request.auth.uid) ||
        (data.participantUids is list && request.auth.uid in data.participantUids)
      );
    }

    function ownsRecord() {
      return (
        (request.resource != null && hasUserOwnership(request.resource.data)) ||
        (resource != null && hasUserOwnership(resource.data))
      );
    }

    match /admins/{uid} {
      allow read: if isSelf(uid) || isAdmin();
      allow write: if isAdmin();
    }

    match /userLookup/{uid} {
      allow read: if isAuthenticated();
      allow write: if isSelf(uid) || isAdmin();
    }

    match /users/{userId} {
      allow read: if isSelf(userId) || isAdmin();
      allow write: if isSelf(userId) || isAdmin();
    }

    match /userSecurity/{userId} {
      allow read: if isSelf(userId) || isAdmin();
      allow write: if isSelf(userId) || isAdmin();
    }

    match /users/{userId}/followedBusinesses/{businessId} {
      allow read: if isSelf(userId) || isAdmin();
      allow write: if isSelf(userId) || isAdmin();
    }

    match /users/{userId}/groupMemberships/{groupId} {
      allow read: if isSelf(userId) || isAdmin();
      allow write: if isSelf(userId) || isAdmin();
    }

    match /users/{userId}/notifications/{notificationId} {
      allow read: if isSelf(userId) || isAdmin();
      allow create: if isSelf(userId) || isAdmin() || (
        isAuthenticated() &&
        request.resource.data.ownerUid is string &&
        request.resource.data.ownerUid == request.auth.uid
      );
      allow update, delete: if isSelf(userId) || isAdmin();
    }

    match /users/{userId}/mobilePushTokens/{tokenId} {
      allow read, write: if isSelf(userId) || isAdmin();
    }

    match /users/{userId}/employments/{employmentId} {
      allow read: if isSelf(userId) || isAdmin() || (
        isAuthenticated() &&
        resource.data.ownerUid is string &&
        resource.data.ownerUid == request.auth.uid
      );
      allow write: if isSelf(userId) || isAdmin() || isEmploymentOwnerWrite();
    }

    match /users/{userId}/performanceReviews/{reviewId} {
      allow read: if isSelf(userId) || isAdmin() || (
        isAuthenticated() &&
        resource.data.reviewedByUid is string &&
        resource.data.reviewedByUid == request.auth.uid
      );
      allow write: if isSelf(userId) || isAdmin() || isPerformanceReviewerWrite();
    }

    match /wallets/{userId} {
      allow read, write: if isSelf(userId) || isAdmin();
    }

    match /wallets/{userId}/transactions/{txId} {
      allow read, write: if isSelf(userId) || isAdmin();
    }

    match /supportTickets/{ticketId} {
      allow read: if isAdmin() || isTicketParticipantData(resource.data);
      allow create: if isAuthenticated() &&
        request.resource.data.customerUid is string &&
        request.resource.data.customerUid == request.auth.uid;
      allow update, delete: if isAdmin() || isTicketParticipantData(resource.data);
    }

    match /supportTickets/{ticketId}/messages/{messageId} {
      allow read: if isAdmin() || isTicketParticipant(ticketId);
      allow create: if (isAdmin() || isTicketParticipant(ticketId)) &&
        request.resource.data.senderUid is string &&
        request.resource.data.senderUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /notificationEndpoints/{endpointId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /notificationDeliveryLogs/{logId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /mobilePushQueue/{queueId} {
      allow read: if isAdmin() || (
        isAuthenticated() &&
        (
          (resource.data.recipientUid is string && resource.data.recipientUid == request.auth.uid) ||
          (resource.data.ownerUid is string && resource.data.ownerUid == request.auth.uid) ||
          (resource.data.actorUid is string && resource.data.actorUid == request.auth.uid)
        )
      );
      allow create: if isAuthenticated() &&
        request.resource.data.recipientUid is string &&
        request.resource.data.ownerUid is string &&
        request.resource.data.actorUid is string &&
        request.resource.data.actorUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /membershipBusinessPrograms/{programId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /membershipApiUsageBuckets/{bucketId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /paymentIntents/{intentId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /payouts/{payoutId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /withdrawalRequests/{requestId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /auditEvents/{eventId} {
      allow read: if isAdmin();
      allow create: if isAdmin() || (
        isAuthenticated() &&
        request.resource.data.actorUid is string &&
        request.resource.data.actorUid == request.auth.uid
      );
      allow update, delete: if isAdmin();
    }

    match /automationJobRuns/{runId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /partnershipDeals/{dealId} {
      allow read: if isAdmin() || isPartnershipParticipant(dealId);
      allow create: if isAuthenticated() && ownsRecord();
      allow update, delete: if isAdmin() || isPartnershipParticipant(dealId);
    }

    match /partnershipDeals/{dealId}/messages/{messageId} {
      allow read: if isAdmin() || isPartnershipParticipant(dealId);
      allow create: if (isAdmin() || isPartnershipParticipant(dealId)) &&
        request.resource.data.senderUid is string &&
        request.resource.data.senderUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /businessApplications/{applicationId} {
      allow read: if resource.data.status == "approved" ||
        (isAuthenticated() && resource.data.ownerUid is string && resource.data.ownerUid == request.auth.uid) ||
        isAdmin();
      allow create: if isAuthenticated() &&
        request.resource.data.ownerUid is string &&
        request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isAdmin() || (
        isAuthenticated() &&
        resource.data.ownerUid is string &&
        resource.data.ownerUid == request.auth.uid
      );
    }

    match /businessApplications/{applicationId}/employees/{employeeUid} {
      allow read: if isAdmin() || isBusinessOwner(applicationId) || isSelf(employeeUid);
      allow write: if isAdmin() || isBusinessOwner(applicationId);
    }

    match /businessApplications/{applicationId}/employeeRequests/{employeeUid} {
      allow read: if isAdmin() || isBusinessOwner(applicationId) || isSelf(employeeUid);
      allow create: if isAdmin() || isBusinessOwner(applicationId) || isSelf(employeeUid);
      allow update, delete: if isAdmin() || isBusinessOwner(applicationId) || isSelf(employeeUid);
    }

    match /businessApplications/{applicationId}/questions/{questionId} {
      allow read: if resource.data.mode == "public" ||
        isAdmin() ||
        isBusinessOwner(applicationId) ||
        (
          isAuthenticated() &&
          (
            (resource.data.customerUid is string && resource.data.customerUid == request.auth.uid) ||
            (resource.data.ownerUid is string && resource.data.ownerUid == request.auth.uid) ||
            (resource.data.participantUids is list && request.auth.uid in resource.data.participantUids)
          )
        );
      allow create: if isAuthenticated() &&
        request.resource.data.customerUid is string &&
        request.resource.data.customerUid == request.auth.uid &&
        request.resource.data.businessId is string &&
        request.resource.data.businessId == applicationId;
      allow update, delete: if isAdmin() ||
        isBusinessOwner(applicationId) ||
        (
          isAuthenticated() &&
          (
            (resource.data.customerUid is string && resource.data.customerUid == request.auth.uid) ||
            (resource.data.ownerUid is string && resource.data.ownerUid == request.auth.uid) ||
            (resource.data.participantUids is list && request.auth.uid in resource.data.participantUids)
          )
        );
    }

    match /businessApplications/{applicationId}/questions/{questionId}/messages/{messageId} {
      allow read: if canReadQuestionThread(applicationId, questionId);
      allow create: if (
          isAdmin() ||
          isBusinessOwner(applicationId) ||
          isQuestionParticipant(applicationId, questionId)
        ) &&
        request.resource.data.senderUid is string &&
        request.resource.data.senderUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /digitalProducts/{productId} {
      allow read: if true;
      allow write: if isAdmin() || ownsRecord();
    }

    match /orders/{orderId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /escrowEntries/{entryId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /invoices/{invoiceId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /proDepositLedgers/{ledgerId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /partnershipFeeLedgers/{ledgerId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /membershipPurchases/{purchaseId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /membershipTransactions/{txId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /membershipBusinessReports/{reportId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /membershipDistributionCycles/{cycleId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /membershipDiscountChecks/{checkId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /productOfferBroadcastLogs/{logId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /verifierCustomerMemberships/{membershipId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /businessVerificationTiers/{businessId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() || ownsRecord();
    }

    match /trustTimelineEvents/{eventId} {
      allow read: if (resource.data.visibility == "public") || isAdmin() || ownsRecord();
      allow create, update, delete: if isAdmin() || ownsRecord();
    }

    match /disputeSlaBreaches/{breachId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /ticketEvidenceAssessments/{assessmentId} {
      allow read, write: if isAdmin();
    }

    match /merchantRiskProfiles/{profileId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /integrationApiKeys/{keyId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /widgetConversionSnapshots/{snapshotId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /crmLeads/{leadId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /crmSegments/{segmentId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /crmCampaigns/{campaignId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /referralPrograms/{programId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /referralInvites/{inviteId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /complianceProfiles/{profileId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /complianceDocuments/{documentId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /businessShopCoupons/{couponId} {
      allow read: if (resource.data.active == true) || isAdmin() || ownsRecord();
      allow create, update, delete: if isAdmin() || ownsRecord();
    }

    match /businessShopTaxRules/{ruleId} {
      allow read: if (resource.data.active == true) || isAdmin() || ownsRecord();
      allow create, update, delete: if isAdmin() || ownsRecord();
    }

    match /businessShopShippingZones/{zoneId} {
      allow read: if (resource.data.active == true) || isAdmin() || ownsRecord();
      allow create, update, delete: if isAdmin() || ownsRecord();
    }

    match /shopInventoryLogs/{logId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /abandonedCheckouts/{checkoutId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /businessServices/{serviceId} {
      allow read: if true;
      allow write: if isAdmin() || ownsRecord();
    }

    match /digitalProducts/{productId}/favorites/{userId} {
      allow read: if isAuthenticated();
      allow write: if isSelf(userId) || isAdmin();
    }

    match /productReviews/{reviewId} {
      allow read: if true;
      allow write: if isAdmin() || ownsRecord();
    }

    match /groups/{groupId} {
      allow read: if true;
      allow write: if isAdmin() || ownsRecord();
    }

    match /groups/{groupId}/messages/{messageId} {
      allow read: if true;
      allow write: if isAuthenticated() && (
        isAdmin() ||
        ownsRecord() ||
        (request.resource != null &&
          request.resource.data.senderUid is string &&
          request.resource.data.senderUid == request.auth.uid)
      );
    }

    match /platformSettings/{settingId} {
      allow read: if settingId in ["homepage", "ads", "geoCatalog"] || isAuthenticated();
      allow write: if isAdmin();
    }

    match /geoCatalogCountries/{countryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /certificates/{certificateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /adCampaigns/{campaignId} {
      allow read: if resource.data.status == "active" || isAdmin() || ownsRecord();
      allow write: if isAdmin() || ownsRecord();
    }

    match /catalogIntegrations/{integrationId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /catalogSyncRuns/{runId} {
      allow read, write: if isAdmin() || ownsRecord();
    }

    match /businessShops/{shopId} {
      allow read: if true;
      allow write: if isAdmin() || ownsRecord();
    }

    match /apiRateLimits/{rateLimitId} {
      allow read, create, update: if true;
      allow delete: if isAdmin();
    }

    match /apiAbuseSignals/{signalId} {
      allow read: if isAdmin();
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    match /trustBadgeWidgetDailyStats/{statId} {
      allow read: if isAdmin() || (
        isAuthenticated() &&
        resource.data.ownerUid is string &&
        resource.data.ownerUid == request.auth.uid
      );
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
